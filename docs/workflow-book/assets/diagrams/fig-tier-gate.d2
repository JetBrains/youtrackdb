# fig-tier-gate — the tier-gate decision tree.
# Two gate questions route a change to one of three tiers; each leaf lists
# the Phase-1 artifact set that tier produces. Source of fact:
# .claude/workflow/planning.md §Tier classification and
# .claude/workflow/conventions.md §Per-tier artifact set (verified at the
# working tree, HEAD f31e961c6a). Rendered by render-diagrams.sh to
# fig-tier-gate.svg; do not hand-edit the SVG.

direction: down

gate1: {
  label: "Gate 1\nIs a design question central\nto the change?"
  shape: diamond
  style.fill: "#fff3cd"
}

gate2: {
  label: "Gate 2\nDoes the change span\nmore than one track?"
  shape: diamond
  style.fill: "#fff3cd"
}

full: {
  label: "full\n\nresearch log\nphase ledger\nplan-review doc\ndesign.md  (only here)\nthinned plan\ntrack files (N)"
  shape: rectangle
  style.fill: "#d4edda"
}

lite: {
  label: "lite\n\nresearch log\nphase ledger\nplan-review doc\nthinned plan\ntrack files (N)\n(no design.md)"
  shape: rectangle
  style.fill: "#d1ecf1"
}

minimal: {
  label: "minimal\n\nresearch log\nphase ledger\nplan-review doc\none track file\n(no design.md, no plan)"
  shape: rectangle
  style.fill: "#f8d7da"
}

gate1 -> full: "yes\n(design needed → multi-track\nby construction)"
gate1 -> gate2: "no"
gate2 -> lite: "multiple tracks"
gate2 -> minimal: "one track"
